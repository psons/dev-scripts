#!/usr/bin/env python3
"""worksum - summarize git diff changes via Gemini CLI and append to docs/dev/work/do.md"""

import sys
import os
import subprocess
import argparse
import datetime

DO_MD_RELATIVE = os.path.join("docs", "dev", "work", "do.md")
WORK_SUMMARY_HEADING = "# Work Summary"
ALT_WORK_SUMMARY_HEADING = "# work summary"

SUMMARY_PROMPT = (
    "You are a technical writer. Summarize the git diff from stdin into a concise, "
    "human-readable work summary. Focus on what changed and why it matters, not raw diff "
    "mechanics. Use plain prose (no bullets unless there are clearly distinct work "
    "streams). Be specific about file names and functionality. Keep the summary to 3-6 "
    "sentences. Return only the summary text."
)


def find_repo_root():
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print("Error: not inside a git repository.", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def get_diff(repo_root, staged=False, base=None):
    """Get git diff output."""
    cmd = ["git", "diff"]
    if staged:
        cmd.append("--staged")
    if base:
        cmd.append(base)
    result = subprocess.run(cmd, capture_output=True, text=True, cwd=repo_root)
    if result.returncode != 0:
        print(f"Error running git diff: {result.stderr}", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def call_gemini(diff_text, model=None):
    """Send diff to Gemini CLI and return the summary text."""
    cmd = ["gemini", "-p", SUMMARY_PROMPT]
    if model:
        cmd.extend(["-m", model])

    env = os.environ.copy()
    # Gemini CLI expects GEMINI_API_KEY. If users already export GOOGLE_API_KEY,
    # map it automatically for compatibility.
    if not env.get("GEMINI_API_KEY") and env.get("GOOGLE_API_KEY"):
        env["GEMINI_API_KEY"] = env["GOOGLE_API_KEY"]

    try:
        result = subprocess.run(
            cmd,
            input=diff_text,
            capture_output=True,
            text=True,
            env=env
        )
    except FileNotFoundError:
        print("Error: gemini CLI not found in PATH.", file=sys.stderr)
        print("Install Gemini CLI and ensure it is available as 'gemini'.", file=sys.stderr)
        sys.exit(1)

    if result.returncode != 0:
        print("Error: gemini CLI failed to generate summary.", file=sys.stderr)
        if result.stderr.strip():
            print(result.stderr.strip(), file=sys.stderr)
        if "GEMINI_API_KEY" in result.stderr:
            print(
                "Set GEMINI_API_KEY (or GOOGLE_API_KEY) in your shell environment and retry.",
                file=sys.stderr,
            )
        sys.exit(1)

    summary = result.stdout.strip()
    if not summary:
        print("Error: gemini CLI returned an empty summary.", file=sys.stderr)
        sys.exit(1)

    return summary


def get_do_md_path(repo_root):
    return os.path.join(repo_root, DO_MD_RELATIVE)


def append_summary(do_md_path, summary_text):
    """Append (or update) the # work summary section at the end of do.md."""
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
    entry = f"\n## {timestamp}\n\n{summary_text}\n"

    if not os.path.exists(do_md_path):
        print(f"Error: {do_md_path} not found.", file=sys.stderr)
        sys.exit(1)

    with open(do_md_path, "r") as f:
        content = f.read()

    heading = None
    if ALT_WORK_SUMMARY_HEADING in content:
        heading = ALT_WORK_SUMMARY_HEADING
    elif WORK_SUMMARY_HEADING in content:
        heading = WORK_SUMMARY_HEADING

    if heading:
        # Normalize section location by rebuilding it at the end of the document.
        split_index = content.index(heading)
        body_before_section = content[:split_index].rstrip("\n")
        existing_section = content[split_index + len(heading):].strip("\n")

        section_body = existing_section
        if section_body:
            section_body += entry
        else:
            section_body = entry.strip("\n") + "\n"

        new_content = (
            body_before_section
            + "\n\n"
            + ALT_WORK_SUMMARY_HEADING
            + "\n\n"
            + section_body.strip("\n")
            + "\n"
        )
    else:
        # Add the section at the end.
        new_content = content.rstrip("\n") + f"\n\n{ALT_WORK_SUMMARY_HEADING}\n{entry}"

    with open(do_md_path, "w") as f:
        f.write(new_content)

    print(f"Work summary appended to {DO_MD_RELATIVE}")


def main():
    parser = argparse.ArgumentParser(
        prog="worksum",
        description="Summarize git diff changes via Gemini CLI and append to docs/dev/work/do.md"
    )
    parser.add_argument(
        "--staged", action="store_true",
        help="Diff staged (index) changes instead of working tree"
    )
    parser.add_argument(
        "--base", metavar="REF",
        help="Compare against a specific commit/branch (e.g. HEAD~1, main)"
    )
    parser.add_argument(
        "--dry-run", action="store_true",
        help="Print the summary to stdout without writing to do.md"
    )
    parser.add_argument(
        "--model", metavar="MODEL",
        help="Gemini model name to use (e.g. gemini-2.5-pro)"
    )
    args = parser.parse_args()

    repo_root = find_repo_root()
    diff = get_diff(repo_root, staged=args.staged, base=args.base)

    if not diff:
        print("No changes found in diff. Nothing to summarize.")
        sys.exit(0)

    print("Summarizing diff...", file=sys.stderr)
    summary = call_gemini(diff, model=args.model)

    if args.dry_run:
        print(summary)
    else:
        do_md_path = get_do_md_path(repo_root)
        append_summary(do_md_path, summary)
        print(summary)


if __name__ == "__main__":
    main()
