#!/usr/bin/env python3

"""
clean-node-modules: Safely delete node_modules and manage package-lock.json files

This utility searches for Node.js projects and provides commands to list
project status, add missing lockfiles, and safely delete node_modules
only when the project can be reconstituted via an existing lockfile.
"""

import argparse
import shutil
import subprocess
import sys
from pathlib import Path


# Supported lockfile names that indicate a Node project
LOCKFILES = {
    'package-lock.json',  # npm
    'yarn.lock',          # yarn
    'pnpm-lock.yaml',     # pnpm
    'package.json',       # fallback - indicates Node project
}


def is_node_project(directory: Path) -> bool:
    return any((directory / lockfile).exists() for lockfile in LOCKFILES)


def has_lockfile(directory: Path) -> bool:
    lockfiles_to_check = LOCKFILES - {'package.json'}
    return any((directory / lockfile).exists() for lockfile in lockfiles_to_check)


def has_node_modules(directory: Path) -> bool:
    return (directory / 'node_modules').is_dir()


def get_safety_reason(directory: Path) -> str:
    if not (directory / 'package.json').exists():
        return "No package.json found"
    if not has_lockfile(directory):
        return "No lockfile found"
    return ""


def find_node_projects(root_path: Path) -> list[tuple[Path, Path]]:
    projects = []
    try:
        for item in root_path.rglob('.'):
            if not item.is_dir():
                continue
            parts = item.parts
            # Skip directories nested inside node_modules, or inside any hidden
            # directory (e.g. .git, .cache) relative to the search root.
            if 'node_modules' in parts or any(p.startswith('.') for p in parts[len(root_path.parts):]):
                continue
            if is_node_project(item):
                rel_path = item.relative_to(root_path)
                projects.append((item, rel_path))
    except (PermissionError, OSError):
        pass
    return sorted(projects, key=lambda x: str(x[1]))


def resolve_root(root_arg: str) -> Path:
    root_path = Path(root_arg).expanduser().resolve()
    if not root_path.is_dir():
        print(f"Error: '{root_arg}' is not a valid directory", file=sys.stderr)
        sys.exit(1)
    return root_path


def cmd_list(args: argparse.Namespace) -> None:
    root_path = resolve_root(args.root)
    projects = find_node_projects(root_path)
    if not projects:
        print(f"No Node.js projects found under {root_path}")
        return
    for abs_path, rel_path in projects:
        has_nm = has_node_modules(abs_path)
        is_safe = has_lockfile(abs_path)
        reason = get_safety_reason(abs_path)

        status_parts = []
        if has_nm:
            status_parts.append("node_modules exists")
        else:
            status_parts.append("no node_modules")

        if is_safe:
            status_parts.append("lockfile present")
        else:
            status_parts.append(f"unsafe: {reason}")

        print(f"{rel_path} [{' | '.join(status_parts)}]")


def cmd_addlock(args: argparse.Namespace) -> None:
    root_path = resolve_root(args.root)
    projects = find_node_projects(root_path)
    if not projects:
        print(f"No Node.js projects found under {root_path}")
        return
    for abs_path, rel_path in projects:
        lock_path = abs_path / 'package-lock.json'
        if lock_path.exists():
            print(f"{rel_path} package-lock.json already exists")
        else:
            print(f"{rel_path} running npm install --package-lock-only ...")
            try:
                result = subprocess.run(
                    ['npm', 'install', '--package-lock-only'],
                    cwd=abs_path,
                    capture_output=True,
                    text=True,
                )
                if result.returncode == 0:
                    print(f"{rel_path} package-lock.json created")
                else:
                    print(f"{rel_path} npm install --package-lock-only failed: {result.stderr.strip()}")
            except FileNotFoundError:
                print(f"{rel_path} Error: npm not found on PATH", file=sys.stderr)
            except OSError as e:
                print(f"{rel_path} Error: {e}", file=sys.stderr)


def cmd_delete(args: argparse.Namespace) -> None:
    root_path = resolve_root(args.root)
    projects = find_node_projects(root_path)
    if not projects:
        print(f"No Node.js projects found under {root_path}")
        return
    for abs_path, rel_path in projects:
        if not has_node_modules(abs_path):
            continue
        reason = get_safety_reason(abs_path)
        if reason:
            print(f"{rel_path} {reason}")
        else:
            try:
                shutil.rmtree(abs_path / 'node_modules')
                print(f"{rel_path} node_modules deleted.")
            except Exception as e:
                print(f"{rel_path} Error deleting node_modules: {e}")


def main():
    parser = argparse.ArgumentParser(
        prog='clean_node_modules',
        description='Safely delete node_modules and manage package-lock.json files in Node.js projects.',
        add_help=True,
    )

    subparsers = parser.add_subparsers(dest='command')

    # help command
    subparsers.add_parser('help', help='Show this help message and exit.')

    # list command
    list_parser = subparsers.add_parser(
        'list',
        help='List all Node projects and their lockfile/node_modules status.'
    )
    list_parser.add_argument(
        '--find', '-f',
        dest='root',
        default='.',
        help='Root directory to search (defaults to current directory)'
    )

    # addlock command
    addlock_parser = subparsers.add_parser(
        'addlock',
        help='Add package-lock.json to projects missing one.'
    )
    addlock_parser.add_argument(
        '--find', '-f',
        dest='root',
        default='.',
        help='Root directory to search (defaults to current directory)'
    )

    # delete command
    delete_parser = subparsers.add_parser(
        'delete',
        help='Safely delete node_modules in projects that have a valid lockfile.'
    )
    delete_parser.add_argument(
        '--find', '-f',
        dest='root',
        default='.',
        help='Root directory to search (defaults to current directory)'
    )

    args = parser.parse_args()

    if args.command is None or args.command == 'help':
        parser.print_help()
        return

    dispatch = {
        'list': cmd_list,
        'addlock': cmd_addlock,
        'delete': cmd_delete,
    }
    dispatch[args.command](args)


if __name__ == '__main__':
    main()
