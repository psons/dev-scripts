#!/usr/bin/env python3
import subprocess
import os
import google.generativeai as genai

# 1. Configuration
# It is best practice to set this as an environment variable
# export GEMINI_API_KEY='your-api-key-here'
api_key = os.getenv("GEMINI_API_KEY")

if not api_key:
    raise ValueError("Please set the GOOGLE_API_KEY environment variable.")

genai.configure(api_key=api_key)
#model = genai.GenerativeModel('gemini-1.5-flash')
model = genai.GenerativeModel('gemini-2.5-flash-lite')
 

def get_git_diff():
    """Captures the output of git diff."""
    try:
        # We use --no-color to ensure the LLM doesn't get confused by ANSI escape codes
        result = subprocess.run(
            ['git', 'diff', 'HEAD'], 
            capture_output=True, 
            text=True, 
            check=True
        )
        return result.stdout
    except subprocess.CalledProcessError as e:
        print(f"Error running git diff: {e}")
        return None

def summarize_changes(diff_text):
    """Sends the diff to Gemini and returns a summary."""
    if not diff_text.strip():
        return "No changes detected since the last commit."

    prompt = f"""
    You are an expert software developer. Please provide a concise, high-level 
    summary of the following git diff. Focus on the 'why' and 'what' rather 
    than listing every line changed. Use bullet points.

    GIT DIFF:
    {diff_text}
    """

    response = model.generate_content(prompt)
    return response.text

if __name__ == "__main__":
    print("Reading git changes...")
    diff = get_git_diff()
    
    if diff:
        print("Generating summary...\n")
        summary = summarize_changes(diff)
        print("--- CHANGE SUMMARY ---")
        print(summary)
    else:
        print("No diff found or not a git repository.")
