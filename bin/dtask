#!/usr/bin/env python3
"""dtask - manage git branch and commit messages for the current task using docs/dev/work/do.md"""

import sys
import os
import subprocess
import argparse
import signal
import threading

try:
    import yaml
except ImportError:
    print("Error: PyYAML is required. Install with: pip install pyyaml", file=sys.stderr)
    sys.exit(1)

DO_MD_RELATIVE = os.path.join("docs", "dev", "work", "do.md")

DO_MD_DESCRIPTION = (
    "A list of small, focused tasks guiding the current commit with detailed microsected activities."
)
DO_MD_TITLE = ("do.md")

DO_MD_BODY = """

"""

FINAL_DO_MD_REMOVAL_COMMIT_MESSAGE = "removed do.md for finalized tasks"


def find_repo_root():
    """Return the root directory of the current git repo."""
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print("Error: not inside a git repository.", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def get_do_md_path(repo_root):
    return os.path.join(repo_root, DO_MD_RELATIVE)


def get_current_commit(repo_root):
    result = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        capture_output=True, text=True, cwd=repo_root
    )
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def is_working_tree_dirty(repo_root):
    result = subprocess.run(
        ["git", "status", "--porcelain"],
        capture_output=True, text=True, cwd=repo_root
    )
    return bool(result.stdout.strip())


def is_file_modified(repo_root, path):
    """Return True if path has been modified (staged or unstaged) since the last commit."""
    result = subprocess.run(
        ["git", "status", "--porcelain", path],
        capture_output=True, text=True, cwd=repo_root
    )
    return bool(result.stdout.strip())


def has_staged_changes(repo_root):
    """Return True if there are staged changes ready to commit."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        cwd=repo_root
    )
    return result.returncode == 1


def read_do_md(path):
    """Read and parse do.md, returning (frontmatter_dict, body_str)."""
    with open(path, "r") as f:
        content = f.read()

    if content.startswith("---"):
        parts = content.split("---", 2)
        if len(parts) >= 3:
            fm = yaml.safe_load(parts[1]) or {}
            body = parts[2]
            return fm, body

    return {}, content


def write_do_md(path, frontmatter, body):
    """Write do.md with YAML frontmatter and body."""
    fm_str = yaml.dump(
        frontmatter,
        default_flow_style=False,
        allow_unicode=True,
        default_style='"'
    ).strip()
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        f.write(f"---\n{fm_str}\n---\n{body}")


def git_add_and_commit(repo_root, paths, message):
    """Stage given paths and commit with message."""
    add_result = subprocess.run(
        ["git", "add"] + paths,
        cwd=repo_root
    )
    if add_result.returncode != 0:
        print("Error: git add failed.", file=sys.stderr)
        sys.exit(1)
    commit_result = subprocess.run(
        ["git", "commit", "-m", message],
        cwd=repo_root
    )
    if commit_result.returncode != 0:
        print("Error: git commit failed.", file=sys.stderr)
        sys.exit(1)


def call_wsum_with_timeout(
    repo_root,
    *,
    include_unstaged=False,
    include_untracked=False,
    timeout_sec=45,
):
    """
    Call wsum.summarize_work() with timeout.
    Returns WorkSummaryResult on success, or None on error.
    """
    try:
        # Dynamic import of wsum module
        bin_dir = os.path.dirname(os.path.abspath(__file__))
        sys.path.insert(0, bin_dir)
        import wsum
        
        # Create a result holder to capture output from threaded call
        result_holder = {"result": None, "exception": None}
        
        def run_wsum():
            try:
                # Match summary scope with dtask commit scope.
                result_holder["result"] = wsum.summarize_work(
                    diff_text=None,
                    staged_only=not include_unstaged,
                    base_ref="HEAD",
                    include_unstaged=include_unstaged,
                    include_untracked=include_untracked,
                    file_paths=None,
                    extra_diff_args=None,
                    model=None,
                    max_sentences=6
                )
            except Exception as e:
                result_holder["exception"] = e
        
        thread = threading.Thread(target=run_wsum)
        thread.daemon = True
        thread.start()
        thread.join(timeout=timeout_sec)
        
        if thread.is_alive():
            # Timeout occurred
            print(
                f"Error: wsum.summarize_work() did not complete within {timeout_sec} seconds.",
                file=sys.stderr
            )
            return None
        
        if result_holder["exception"]:
            print(f"Error: wsum.summarize_work() failed: {result_holder['exception']}", file=sys.stderr)
            return None
        
        return result_holder["result"]
    except ImportError:
        print("Error: wsum module could not be imported from bin/", file=sys.stderr)
        return None
    except Exception as e:
        print(f"Error: unexpected error calling wsum: {e}", file=sys.stderr)
        return None


def insert_work_summary_into_do_md(do_md_path, work_headline, summary_markdown):
    """
    Insert WorkSummaryResult.markdown verbatim at the top of the # Work Summary section,
    immediately after the header, before any older summaries.
    """
    with open(do_md_path, "r") as f:
        content = f.read()

    work_summary_header = "# Work Summary"
    header_idx = content.find(work_summary_header)

    if header_idx == -1:
        # No # Work Summary section: add header and insert markdown after it
        new_content = content.rstrip() + f"\n{work_summary_header}\n\n" + summary_markdown.strip() + "\n"
    else:
        # Find the end of the header line
        header_line_end = content.find('\n', header_idx)
        if header_line_end == -1:
            header_line_end = len(content)
        insert_pos = header_line_end + 1

        # Insert the new summary_markdown at insert_pos
        new_content = content[:insert_pos] + summary_markdown.strip() + "\n" + content[insert_pos:]

    with open(do_md_path, "w") as f:
        f.write(new_content)


def cmd_help(_args):
    print("""dtask - manage git branch and commit messages for the current task

Subcommands:
  help    Print this help message.

  init    Initialize a new docs/dev/work/do.md file for the current task.
          Sets priorCommit to the current HEAD commit hash.

          Options:
                        --workbranch, -b <branch>   Required. Create and check out a new
                                                                                git branch.
            --intended,   -i <message>  Set the intendedCommitMessage.
            --actual,     -a <message>  Set the actualCommitMessage.
            --dirty                     Allow init even if the working tree is not
                                        clean. If do.md exists and is dirty, exits
                                        with an error unless --newdo is also given.
            --newdo                     Used with --dirty. Asserts a fresh do.md
                                        should be created. If do.md has been
                                        modified since the last commit it is
                                        committed first ('do.md when <cmd>') and
                                        that commit becomes priorCommit. If do.md
                                        is already committed, it is simply replaced
                                        with no extra commit.

  commit  Commit staged changes on workBranch using workHeadline as the commit message.
          Unstaged changes are only included when --all or --update is used.

             Options:
                --wsum                  Generate work summary using wsum module and update
                                        do.md with workHeadline and summary. Include summary
                                        in this commit.
                --actual, -a [message]  Update actualCommitMessage before committing.
                                                If given with no argument, copies
                                                intendedCommitMessage to actualCommitMessage
                                                (signals task proceeded as expected).
                --all                   Stage and include unstaged changes too
                                                (equivalent to running git add -A first).
                --update, -u            Stage tracked unstaged changes only
                                                (equivalent to running git add --update).
                --final                 Signal task complete. Uses actualCommitMessage
                                        for commit (not workHeadline). Performs two commits:
                                                1) commit do.md with staged changes (or additional changes 
                                                    included when --all or --update is used) with actualCommitMessage;
                                                2) remove do.md and commit with message
                                                    'removed do.md for finalized tasks'.
""")


def cmd_init(args):
    if not args.workbranch:
        print("Error: init requires a branch. Use --workbranch/-b.", file=sys.stderr)
        sys.exit(1)

    repo_root = find_repo_root()
    do_md_path = get_do_md_path(repo_root)
    do_md_exists = os.path.isfile(do_md_path)
    dirty = is_working_tree_dirty(repo_root)
    do_md_dirty = do_md_exists and is_file_modified(repo_root, do_md_path)

    if not args.dirty:
        errors = []
        if dirty:
            errors.append("working tree is dirty")
        if do_md_exists:
            errors.append(f"{DO_MD_RELATIVE} already exists")
        if errors:
            print(f"Error: {' and '.join(errors)}. Use --dirty to override.", file=sys.stderr)
            sys.exit(1)
    else:
        # --dirty without --newdo: error if do.md is dirty
        if do_md_dirty and not args.newdo:
            print(
                f"Error: {DO_MD_RELATIVE} has uncommitted changes. "
                "Use --newdo to commit and replace it.",
                file=sys.stderr
            )
            sys.exit(1)
        # --dirty --newdo: commit dirty do.md before replacing
        if do_md_dirty and args.newdo:
            cmd_str = "dtask init " + " ".join(sys.argv[2:])
            commit_msg = f"do.md when {cmd_str}"
            print(f"Committing existing do.md: {commit_msg}")
            git_add_and_commit(repo_root, [do_md_path], commit_msg)
        # --dirty --newdo with clean do.md: fall through, just overwrite
        if not args.newdo and do_md_exists:
            print(
                f"Error: {DO_MD_RELATIVE} already exists. Use --newdo to replace it.",
                file=sys.stderr
            )
            sys.exit(1)

    # Create workBranch if requested
    if args.workbranch:
        result = subprocess.run(
            ["git", "checkout", "-b", args.workbranch],
            cwd=repo_root
        )
        if result.returncode != 0:
            print(f"Error: git checkout -b {args.workbranch} failed.", file=sys.stderr)
            sys.exit(1)
        print(f"Created and checked out branch: {args.workbranch}")

    prior_commit = get_current_commit(repo_root)

    # Determine current branch for frontmatter
    branch_result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True, text=True, cwd=repo_root
    )
    current_branch = branch_result.stdout.strip() if branch_result.returncode == 0 else ""

    frontmatter = {
        "title": DO_MD_TITLE,
        "description": DO_MD_DESCRIPTION,
        "workBranch": args.workbranch if args.workbranch else current_branch,
        "priorCommit": prior_commit,
        "intendedCommitMessage": args.intended if args.intended else "",
        "actualCommitMessage": args.actual if args.actual else "",
    }

    write_do_md(do_md_path, frontmatter, DO_MD_BODY)
    print(f"Initialized {DO_MD_RELATIVE} (priorCommit: {prior_commit})")


def cmd_commit(args):
    repo_root = find_repo_root()
    do_md_path = get_do_md_path(repo_root)

    if not os.path.isfile(do_md_path):
        print(f"Error: {DO_MD_RELATIVE} not found. Run 'dtask init' first.", file=sys.stderr)
        sys.exit(1)

    frontmatter, body = read_do_md(do_md_path)

    # Track whether dtask itself updated do.md during this command.
    do_md_updated_by_dtask = False

    # Map dtask commit mode to wsum scope.
    # default: staged-only
    # --update: staged + tracked unstaged
    # --all: staged + tracked unstaged + untracked
    wsum_include_unstaged = bool(args.all or args.update)
    wsum_include_untracked = bool(args.all)

    # Handle --wsum: generate work summary and update do.md
    if args.wsum:
        print("Running wsum to generate work summary...")
        wsum_result = call_wsum_with_timeout(
            repo_root,
            include_unstaged=wsum_include_unstaged,
            include_untracked=wsum_include_untracked,
            timeout_sec=45,
        )
        
        if wsum_result is None:
            print("\nUnable to summarize changes. set actualCommitMessage in do.md and try again with --actual", file=sys.stderr)
            sys.exit(1)
        
        # Update do.md with work summary
        try:
            insert_work_summary_into_do_md(
                do_md_path,
                wsum_result.headline,
                wsum_result.markdown
            )
            # Update frontmatter workHeadline
            frontmatter["workHeadline"] = wsum_result.headline
            # Reread do.md after insertion to get updated body, but preserve the workHeadline we just set
            _, body = read_do_md(do_md_path)
            # Write do.md with the updated frontmatter (now includes workHeadline)
            write_do_md(do_md_path, frontmatter, body)
            do_md_updated_by_dtask = True
            print(f"Work summary added to {DO_MD_RELATIVE}")
        except Exception as e:
            print(f"Error: could not insert work summary into do.md: {e}", file=sys.stderr)
            print("Fallback: set actualCommitMessage in do.md and try again.", file=sys.stderr)
            sys.exit(1)

    # Update actualCommitMessage if --actual provided
    _COPY_INTENDED = '__COPY_INTENDED__'
    if args.actual == _COPY_INTENDED:
        # --actual with no argument: copy intendedCommitMessage
        intended = frontmatter.get("intendedCommitMessage", "").strip()
        if not intended:
            print(
                "Error: intendedCommitMessage is empty; cannot copy to actualCommitMessage.",
                file=sys.stderr
            )
            sys.exit(1)
        frontmatter["actualCommitMessage"] = intended
        write_do_md(do_md_path, frontmatter, body)
        do_md_updated_by_dtask = True
    elif args.actual is not None:
        frontmatter["actualCommitMessage"] = args.actual
        write_do_md(do_md_path, frontmatter, body)
        do_md_updated_by_dtask = True

    # Determine commit message.
    # - --final uses actualCommitMessage.
    # - non-final commits without --actual copy workHeadline into actualCommitMessage,
    #   save do.md, and use that value as the commit message.
    if args.final:
        commit_message = frontmatter.get("actualCommitMessage", "").strip()
        if not commit_message:
            print(
                "Error: actualCommitMessage is empty. Set it in do.md or use --actual [<message>].",
                file=sys.stderr
            )
            sys.exit(1)
    elif args.actual is None:
        commit_message = frontmatter.get("workHeadline", "").strip()
        if not commit_message:
            print(
                "Error: workHeadline is empty. Use --wsum to generate it, or set workHeadline in do.md.",
                file=sys.stderr
            )
            sys.exit(1)

        if frontmatter.get("actualCommitMessage", "").strip() != commit_message:
            frontmatter["actualCommitMessage"] = commit_message
            write_do_md(do_md_path, frontmatter, body)
            do_md_updated_by_dtask = True
    else:
        commit_message = frontmatter.get("actualCommitMessage", "").strip()
        if not commit_message:
            print(
                "Error: actualCommitMessage is empty. Set it in do.md or use --actual [<message>].",
                file=sys.stderr
            )
            sys.exit(1)

    work_branch = frontmatter.get("workBranch", "").strip()

    # Verify we are on the correct workBranch
    branch_result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True, text=True, cwd=repo_root
    )
    current_branch = branch_result.stdout.strip() if branch_result.returncode == 0 else ""

    if work_branch and current_branch != work_branch:
        print(
            f"Error: current branch '{current_branch}' does not match workBranch '{work_branch}'.",
            file=sys.stderr
        )
        sys.exit(1)

    # Clarification 2026-05-18: whenever dtask changes do.md, stage it before commit.
    if do_md_updated_by_dtask:
        add_do_md = subprocess.run(["git", "add", do_md_path], cwd=repo_root)
        if add_do_md.returncode != 0:
            print("Error: git add do.md failed after dtask updated it.", file=sys.stderr)
            sys.exit(1)

    # By default, only already-staged changes are committed.
    # --all stages tracked+untracked changes; --update stages tracked changes only.
    if args.all:
        add_all = subprocess.run(["git", "add", "-A"], cwd=repo_root)
        if add_all.returncode != 0:
            print("Error: git add -A failed.", file=sys.stderr)
            sys.exit(1)
    elif args.update:
        add_update = subprocess.run(["git", "add", "--update"], cwd=repo_root)
        if add_update.returncode != 0:
            print("Error: git add --update failed.", file=sys.stderr)
            sys.exit(1)

    # When finalizing without --all or --update, ensure do.md changes are not lost by
    # staging do.md into the first commit before it gets removed.
    do_md_dirty = is_file_modified(repo_root, do_md_path)
    if args.final and not args.all and do_md_dirty:
        add_do_md = subprocess.run(["git", "add", do_md_path], cwd=repo_root)
        if add_do_md.returncode != 0:
            print("Error: git add do.md failed.", file=sys.stderr)
            sys.exit(1)

    has_staged = has_staged_changes(repo_root)
    if not has_staged and not args.final:
        print(
            "Error: no staged changes to commit. Stage files first or use --all/--update.",
            file=sys.stderr
        )
        sys.exit(1)

    # For --final with no staged changes, skip the first commit and only remove do.md.
    if has_staged:
        commit_result = subprocess.run(
            ["git", "commit", "-m", commit_message],
            cwd=repo_root
        )
        if commit_result.returncode != 0:
            print("Error: git commit failed.", file=sys.stderr)
            sys.exit(1)

        print(f"Committed on '{current_branch}': {commit_message}")

    if args.final:
        # Remove do.md and make a second commit
        os.remove(do_md_path)
        rm_result = subprocess.run(
            ["git", "add", do_md_path],
            cwd=repo_root
        )
        if rm_result.returncode != 0:
            print("Error: git add (removal of do.md) failed.", file=sys.stderr)
            sys.exit(1)
        final_commit = subprocess.run(
            ["git", "commit", "-m", FINAL_DO_MD_REMOVAL_COMMIT_MESSAGE],
            cwd=repo_root
        )
        if final_commit.returncode != 0:
            print("Error: git commit (remove do.md) failed.", file=sys.stderr)
            sys.exit(1)
        print(
            f"Removed {DO_MD_RELATIVE} and committed on '{current_branch}': "
            f"{FINAL_DO_MD_REMOVAL_COMMIT_MESSAGE}"
        )


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        cmd_help(None)
        sys.exit(0)

    subcommand = sys.argv[1]

    if subcommand == "help":
        cmd_help(None)

    elif subcommand == "init":
        parser = argparse.ArgumentParser(prog="dtask init", add_help=True)
        parser.add_argument("--workbranch", "-b", dest="workbranch", metavar="BRANCH", default=None)
        parser.add_argument("--intended", "-i", dest="intended", metavar="MESSAGE", default=None)
        parser.add_argument("--actual", "-a", dest="actual", metavar="MESSAGE", default=None)
        parser.add_argument("--dirty", action="store_true", default=False)
        parser.add_argument("--newdo", action="store_true", default=False)
        args = parser.parse_args(sys.argv[2:])
        cmd_init(args)

    elif subcommand == "commit":
        parser = argparse.ArgumentParser(prog="dtask commit", add_help=True)
        parser.add_argument("--wsum", action="store_true", default=False)
        parser.add_argument("--actual", "-a", dest="actual", metavar="MESSAGE",
                            nargs="?", const="__COPY_INTENDED__", default=None)
        mode_group = parser.add_mutually_exclusive_group()
        mode_group.add_argument("--all", action="store_true", default=False)
        mode_group.add_argument("--update", "-u", action="store_true", default=False)
        parser.add_argument("--final", action="store_true", default=False)
        args = parser.parse_args(sys.argv[2:])
        cmd_commit(args)

    else:
        print(f"Error: unknown subcommand '{subcommand}'. Run 'dtask help' for usage.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
 