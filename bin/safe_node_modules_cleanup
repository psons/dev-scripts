#!/usr/bin/env python3

"""
safe-node-modules-cleanup: Safely delete node_modules directories

This utility searches for Node.js projects and safely deletes node_modules
only when the project can be 100% reconstituted via an existing lockfile.
"""

import argparse
import os
import shutil
import sys
from pathlib import Path


# Supported lockfile names that indicate a Node project
LOCKFILES = {
    'package-lock.json',  # npm
    'yarn.lock',          # yarn
    'pnpm-lock.yaml',     # pnpm
    'package.json',       # fallback - indicates Node project
}


def is_node_project(directory: Path) -> bool:
    """Check if a directory is a Node.js project."""
    return any((directory / lockfile).exists() for lockfile in LOCKFILES)


def has_lockfile(directory: Path) -> bool:
    """Check if project has a proper lockfile (not just package.json)."""
    lockfiles_to_check = LOCKFILES - {'package.json'}
    return any((directory / lockfile).exists() for lockfile in lockfiles_to_check)


def has_node_modules(directory: Path) -> bool:
    """Check if node_modules directory exists."""
    return (directory / 'node_modules').is_dir()


def get_safety_reason(directory: Path) -> str:
    """Determine why deletion might not be safe."""
    if not (directory / 'package.json').exists():
        return "No package.json found"
    
    if not has_lockfile(directory):
        return "No lockfile found"
    
    # Can add more checks here in the future (e.g., lockfile validation)
    return ""


def find_node_projects(root_path: Path) -> list[tuple[Path, Path]]:
    """
    Find all Node.js projects under root_path.
    
    Returns a list of tuples (absolute_path, relative_path_from_root)
    """
    projects = []
    
    try:
        for item in root_path.rglob('.'):
            if not item.is_dir():
                continue
            
            # Skip node_modules and hidden directories
            parts = item.parts
            if 'node_modules' in parts or any(p.startswith('.') for p in parts[len(root_path.parts):]):
                continue
            
            if is_node_project(item):
                rel_path = item.relative_to(root_path)
                projects.append((item, rel_path))
    except (PermissionError, OSError):
        pass
    
    return sorted(projects, key=lambda x: str(x[1]))


def process_project_list(projects: list[tuple[Path, Path]]) -> None:
    """Display project list with safety status (--list mode)."""
    for abs_path, rel_path in projects:
        has_nm = has_node_modules(abs_path)
        is_safe = has_lockfile(abs_path)
        reason = get_safety_reason(abs_path)
        
        status_parts = []
        if has_nm:
            status_parts.append("node_modules exists")
        else:
            status_parts.append("no node_modules")
        
        if is_safe:
            status_parts.append("lockfile present")
        else:
            status_parts.append(f"unsafe: {reason}")
        
        status = " | ".join(status_parts)
        print(f"{rel_path} [{status}]")


def process_project_delete(projects: list[tuple[Path, Path]]) -> None:
    """Process projects for safe deletion (default mode)."""
    for abs_path, rel_path in projects:
        if not has_node_modules(abs_path):
            # No node_modules to delete, skip
            continue
        
        reason = get_safety_reason(abs_path)
        
        if reason:
            # Not safe to delete
            print(f"{rel_path} {reason}")
        else:
            # Safe to delete
            try:
                nm_path = abs_path / 'node_modules'
                shutil.rmtree(nm_path)
                print(f"{rel_path} node_modules deleted.")
            except Exception as e:
                print(f"{rel_path} Error deleting node_modules: {e}")


def main():
    parser = argparse.ArgumentParser(
        description='Safely delete node_modules directories when projects can be reconstituted from lockfiles.'
    )
    parser.add_argument(
        '--find', '-f',
        dest='root',
        default='.',
        help='Root directory to begin searching for Node projects (defaults to current directory)'
    )
    parser.add_argument(
        '--list', '-l',
        action='store_true',
        help='List projects and status without deleting anything'
    )
    
    args = parser.parse_args()
    
    root_path = Path(args.root).expanduser().resolve()
    
    if not root_path.is_dir():
        print(f"Error: '{args.root}' is not a valid directory", file=sys.stderr)
        sys.exit(1)
    
    projects = find_node_projects(root_path)
    
    if not projects:
        print(f"No Node.js projects found under {root_path}")
        return
    
    if args.list:
        process_project_list(projects)
    else:
        process_project_delete(projects)


if __name__ == '__main__':
    main()
